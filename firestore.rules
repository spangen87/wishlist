rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(wishlistId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/wishlists/$(wishlistId)) &&
             get(/databases/$(database)/documents/wishlists/$(wishlistId)).data.childUid == request.auth.uid;
    }

    function isViewer(wishlistId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/wishlists/$(wishlistId)) &&
             request.auth.uid in get(/databases/$(database)/documents/wishlists/$(wishlistId)).data.viewerUids;
    }

    function isParent(wishlistId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/wishlists/$(wishlistId)) &&
             request.auth.uid in get(/databases/$(database)/documents/wishlists/$(wishlistId)).data.parentUids;
    }

    // Root wishlist document — child (owner) can read/write their own
    // request.auth.uid == wishlistId covers first-login reads where the doc doesn't exist yet
    // (wishlist ID is deterministically the child's UID, so this is safe)
    // Note: use resource.data directly (not isOwner/isViewer helpers) so collection queries work.
    // isOwner/isViewer call get() on the same document, which Firestore rejects for queries.
    match /wishlists/{wishlistId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == wishlistId ||
        request.auth.uid == resource.data.childUid ||
        request.auth.uid in resource.data.viewerUids ||
        request.auth.uid in resource.data.parentUids
      );
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.childUid
        && request.resource.data.viewerUids == []
        && request.resource.data.parentUids == [];
      // Owner updates must NOT touch the membership fields. If the child could
      // edit viewerUids/parentUids they could add their own UID and pass the
      // isViewer/isParent checks on purchaseStatus + activityLog below — which
      // would break the irreversible privacy boundary (D-03). Membership is
      // managed exclusively by the Admin SDK (invite redemption, removal).
      allow update: if isOwner(wishlistId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['viewerUids', 'parentUids', 'childUid']);
      allow delete: if isOwner(wishlistId);

      // Items subcollection — child-readable AND child-writable (D-02)
      // Viewers can also read items (to show the wishlist to them)
      // isFavorite is child-only: parent updates are allowed only when isFavorite is not affected (B-02)
      match /items/{itemId} {
        // photoData holds an own photo inline as a JPEG data URL (Spark plan
        // has no Cloud Storage). Cap size (must match MAX_PHOTO_DATA_CHARS in
        // src/lib/image.ts) and require a JPEG data URL so nothing executable
        // or oversized can be stored.
        function hasValidPhotoData() {
          return !('photoData' in request.resource.data)
            || (request.resource.data.photoData is string
                && request.resource.data.photoData.size() <= 300000
                && request.resource.data.photoData.matches('data:image/jpeg;base64,[A-Za-z0-9+/=]+'));
        }
        // Cap free-text fields so a single item can't bloat the document
        // (limits must match the server-side caps in the API routes).
        function hasValidItemFields() {
          return request.resource.data.title is string
            && request.resource.data.title.size() >= 1
            && request.resource.data.title.size() <= 200
            && (!('note' in request.resource.data)
                || (request.resource.data.note is string
                    && request.resource.data.note.size() <= 1000))
            && (!('productUrl' in request.resource.data)
                || (request.resource.data.productUrl is string
                    && request.resource.data.productUrl.size() <= 2048
                    && request.resource.data.productUrl.matches('https?://.*')))
            && (!('imageUrl' in request.resource.data)
                || (request.resource.data.imageUrl is string
                    && request.resource.data.imageUrl.size() <= 2048
                    && request.resource.data.imageUrl.matches('https?://.*')));
        }
        allow read: if isAuthenticated() && (isOwner(wishlistId) || isViewer(wishlistId) || isParent(wishlistId));
        allow create: if (isOwner(wishlistId) || isParent(wishlistId))
          && hasValidPhotoData() && hasValidItemFields();
        allow delete: if isOwner(wishlistId) || isParent(wishlistId);
        allow update: if (isOwner(wishlistId) ||
          (isParent(wishlistId) &&
           !resource.data.diff(request.resource.data).affectedKeys().hasAny(['isFavorite'])))
          && hasValidPhotoData() && hasValidItemFields();
      }

      // Purchase status subcollection — viewers AND parents can read, child CANNOT (D-03)
      // This is the irreversible privacy boundary. Child UID is NOT in viewerUids or parentUids.
      // Do NOT add any rule that allows childUid to read this subcollection.
      // All writes go through the API routes (Admin SDK) which enforce that a
      // viewer can only touch their own purchase/reservation/notes — client
      // writes are forbidden so viewers can't tamper with each other's data.
      match /purchaseStatus/{itemId} {
        allow read: if isViewer(wishlistId) || isParent(wishlistId);
        allow write: if false; // Admin SDK only (API routes)
      }

      // Activity log subcollection — viewers AND parents can read, written via Admin SDK only (D-18)
      // Child CANNOT read. Client writes are forbidden (Admin SDK bypasses rules).
      match /activityLog/{entryId} {
        allow read: if isViewer(wishlistId) || isParent(wishlistId);
        allow write: if false;
      }
    }

    // Username → UID mapping (D-04)
    // Public read — needed for unauthenticated login lookup (only stores uid, not sensitive)
    // Only the Admin SDK (server-only) writes these — no client write rule needed
    match /usernames/{username} {
      allow read: if true;
      allow write: if false; // Admin SDK only
    }

    // User profiles (D-04)
    // Any authenticated user can read profiles (needed for viewers to resolve child display names).
    // Only the owner can write their own profile.
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }

    // Invite tokens (D-04)
    // Share link redemption via API Route + Admin SDK only — client SDK never reads invites
    match /invites/{token} {
      allow read, write: if false; // Admin SDK only, client never touches this
    }
  }
}
